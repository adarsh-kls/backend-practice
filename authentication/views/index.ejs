<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h1 class="text-3xl font-bold mb-6">Create User</h1>
        <form method="post" action="/create">
            <input class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="text"
                placeholder="username" name="username">
            <input class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="email" placeholder="email"
                name="email">
            <input class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="password"
                placeholder="password" name="password">
            <input class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="number" placeholder="age"
                name="age">
            <button class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600" type="submit">Create
                User</button>
        </form>
    </div>

</body>

</html>