<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>

        <h3 class="text-3xl font-bold mb-5">
            <span class="font-light">Hello, </span>
            <%= user.username %>!
        </h3>

        <h5 class="text-lg font-light mb-5">You can create a post.</h5>

        <form action="/post" method="POST">
            <textarea
                placeholder="what's on your mind?"
                class="p-3 outline-none w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md"
                name="content"></textarea>

            <input
                class="px-3 py-2 w-40 bg-blue-500 block mt-2"
                type="submit"
                value="Create Post">
        </form>

        <div class="post mt-20">
            <h3 class="text-zinc-400">Your Posts.</h3>

            <div class="postcontainer mt-5">

                <% user.posts.forEach(function(post){ %>

                <div class="post w-1/3 p-4 mb-5 rounded-md border-2 border-zinc-700 bg-zinc-800">

                    <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>

                    <p class="text-sm tracking-tight">
                        <%= post.content %>
                    </p>

                    <div class="btns flex gap-4 mt-5">
                        <a class="text-blue-500" href="#">Like</a>
                        <a class="text-blue-600" href="#">Edit</a>
                    </div>

                </div>

                <% }) %>

            </div>
        </div>

    </div>
</body>

</html>